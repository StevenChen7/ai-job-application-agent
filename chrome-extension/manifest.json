{
  "manifest_version": 3,
  "name": "AI Job Agent Page Importer",
  "version": "1.0.0",
  "description": "Send the current job page text to the local AI Job Application Agent.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:*/", "http://localhost:*/"],
  "action": {
    "default_title": "Import job page",
    "default_popup": "popup.html"
  }
}
